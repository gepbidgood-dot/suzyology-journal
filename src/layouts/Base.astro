---
import '../styles/global.css';

interface Props {
  title: string;
  isArticle?: boolean;
}
const { title, isArticle = false } = Astro.props;
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{title} — Suzyology Journal</title>
</head>
<body>

<div id="sz-left-panel">
  <a id="sz-logo" href="https://suzyology.com">
    <img src="/logo.png" alt="Suzyology">
  </a>
  <nav id="sz-panel-nav">
    <a href="https://suzyology.com">Suzyology</a>
    <a href="/" class={!isArticle ? 'active' : ''}>journal</a>
  </nav>
</div>

<main id="sz-main">
  <slot />
</main>

<script>
  function szFadeTo(el: HTMLElement, to: number, ms: number) {
    el.style.transition = `opacity ${ms}ms ease`;
    el.style.opacity = String(to);
  }

  function szFadeOut(cb: () => void) {
    const nav = document.getElementById('sz-panel-nav') as HTMLElement;
    const main = document.getElementById('sz-main') as HTMLElement;
    if (nav) szFadeTo(nav, 0, 200);
    if (main) szFadeTo(main, 0, 200);
    setTimeout(cb, 220);
  }

  // Intercept internal links
  document.addEventListener('click', function(e) {
    const a = (e.target as HTMLElement).closest('a') as HTMLAnchorElement | null;
    if (!a || !a.href) return;
    try { if (new URL(a.href).origin !== location.origin) return; } catch { return; }
    e.preventDefault();
    const href = a.href;
    szFadeOut(() => { window.location.href = href; });
  }, true);

  // Fade in on arrival — use RAF to ensure paint before transition
  document.addEventListener('DOMContentLoaded', () => {
    const nav = document.getElementById('sz-panel-nav') as HTMLElement;
    const main = document.getElementById('sz-main') as HTMLElement;
    if (nav) nav.style.opacity = '0';
    if (main) main.style.opacity = '0';
    requestAnimationFrame(() => {
      requestAnimationFrame(() => {
        if (nav) szFadeTo(nav, 1, 300);
        if (main) szFadeTo(main, 1, 300);
      });
    });
  });
</script>

</body>
</html>
