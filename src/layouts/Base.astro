---
import '../styles/global.css';

interface Props {
  title: string;
  isArticle?: boolean;
}
const { title, isArticle = false } = Astro.props;
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{title} — Suzyology Journal</title>
</head>
<body>

<div id="sz-left-panel">
  <a id="sz-logo" href="https://suzyology.com">
    <img id="sz-emoji-img" src="/logo.png" alt="Suzyology"
      data-normal="/logo.png"
      data-emotions="/sz-emotion-1.png,/sz-emotion-2.png,/sz-emotion-3.png,/sz-emotion-4.png,/sz-emotion-5.png,/sz-emotion-6.png">
  </a>
  <nav id="sz-panel-nav">
    <a href="https://suzyology.com">Suzyology</a>
    <a href="/" class={!isArticle ? 'active' : ''}>journal</a>
  </nav>
</div>

<main id="sz-main">
  <slot />
</main>

<footer id="sz-footer">
  <img src="/sz-footer-paper.jpeg" alt="">
  <div id="sz-footer-text">
    <div class="sz-footer-left">
      <span>© Suzyology</span>
      <span>Melbourne</span>
    </div>
    <div class="sz-footer-right">
      <a href="mailto:orders@suzyology.com">orders@suzyology.com</a>
      <a href="https://suzyology.com/pages/stockists">stockists</a>
    </div>
  </div>
</footer>

<script>
  function szFadeTo(el: HTMLElement, to: number, ms: number) {
    el.style.transition = `opacity ${ms}ms ease`;
    el.style.opacity = String(to);
  }

  function szFadeOut(cb: () => void) {
    const nav = document.getElementById('sz-panel-nav') as HTMLElement;
    const main = document.getElementById('sz-main') as HTMLElement;
    if (nav) szFadeTo(nav, 0, 200);
    if (main) szFadeTo(main, 0, 200);
    setTimeout(cb, 220);
  }

  // Intercept internal links
  document.addEventListener('click', function(e) {
    const a = (e.target as HTMLElement).closest('a') as HTMLAnchorElement | null;
    if (!a || !a.href) return;
    e.preventDefault();
    const href = a.href;
    szFadeOut(() => { window.location.href = href; });
  }, true);

  // Fade in on arrival — use RAF to ensure paint before transition
  document.addEventListener('DOMContentLoaded', () => {
    const nav = document.getElementById('sz-panel-nav') as HTMLElement;
    const main = document.getElementById('sz-main') as HTMLElement;
    if (nav) nav.style.opacity = '0';
    if (main) main.style.opacity = '0';
    requestAnimationFrame(() => {
      requestAnimationFrame(() => {
        if (nav) szFadeTo(nav, 1, 300);
        if (main) szFadeTo(main, 1, 300);
      });
    });
  });

  // Emoji hover emotions
  (function() {
    const img = document.getElementById('sz-emoji-img') as HTMLImageElement | null;
    if (!img) return;
    const normal = img.dataset.normal!;
    const emotions = img.dataset.emotions!.split(',');
    emotions.forEach(s => { const p = new Image(); p.src = s; });
    let last = -1;
    img.addEventListener('mouseenter', () => {
      let idx: number;
      do { idx = Math.floor(Math.random() * emotions.length); } while (idx === last && emotions.length > 1);
      last = idx;
      img.src = emotions[idx];
    });
    img.addEventListener('mouseleave', () => { img.src = normal; });
  })();
</script>

</body>
</html>
